/**
 * And gate:
 * if (a and b) out = 1, else out = 0 
 */
CHIP And {
    IN a, b;
    OUT out;
    
    // AND is the inverse of a NAND
    // therefore, we pump everything into a first NAND
    // then invert to produce the AND
    // thereby making an AND just using NANDs
    PARTS:
    Nand(a=a , b=b, out=out1);
    Nand(a=out1, b=out1, out=out);
}